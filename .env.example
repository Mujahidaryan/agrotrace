# ============================================================
#  AgroTrace v0.2.0 — Environment Variables
#  Copy this to .env.local for local development.
#  Production: set via Vercel Dashboard → Settings → Environment Variables.
#  Railway: set via Railway project → Variables tab.
# ============================================================

# ── APP (required) ──────────────────────────────────────────
# Type: string (URL)
# Required: yes
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Type: string
# Required: no (used in UI labels)
NEXT_PUBLIC_APP_NAME=AgroTrace

# ── DATABASE (required) ─────────────────────────────────────
# Type: string (PostgreSQL connection string)
# Required: yes
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Railway provides this automatically under: ${{Postgres.DATABASE_URL}}
# Vercel: add the Railway internal URL as a Vercel env var.
# Note: Railway public URL uses port 5432. Internal URL uses port 5432 too
#       but with a different hostname — use the internal URL in Vercel for
#       lower latency and no egress charges.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/railway

# ── FEATURE FLAGS (optional) ────────────────────────────────
# Type: boolean ("true" | "false")
# Required: no
NEXT_PUBLIC_ENABLE_LIVE_MAP=true
NEXT_PUBLIC_ENABLE_EXPORT_CSV=true

# ── NODE ENV (set automatically by Vercel/Railway) ──────────
# Type: enum ("development" | "production" | "test")
# Required: no (set by platform)
# NODE_ENV=production
